{
  "name": "sah/sdk",
  "description": "Unified PHP SDK for the ISA Platform (zyins, rapidsign, proxy). Bearer / License / Session factories, idempotent mutations, typed value objects, typed exception funnel. Companion to @software-automation-holdings-llc/sdk (JS), sah-sdk (Python), and github.com/Software-Automation-Holdings-LLC/sdk (Go).",
  "type": "library",
  "license": "Apache-2.0",
  "keywords": [
    "isa",
    "zyins",
    "rapidsign",
    "proxy",
    "insurance",
    "sdk",
    "underwriting",
    "esignature",
    "algosure",
    "hmac"
  ],
  "require": {
    "php": ">=8.2",
    "ext-json": "*",
    "ext-hash": "*",
    "ext-zlib": "*",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.0 || ^2.0",
    "psr/log": "^1.1 || ^2.0 || ^3.0",
    "guzzlehttp/guzzle": "^7.8",
    "guzzlehttp/psr7": "^2.6",
    "ramsey/uuid": "^4.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.59",
    "nyholm/psr7": "^1.8",
    "rector/rector": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "Isa\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Isa\\Sdk\\Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.5-dev"
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit --no-coverage",
    "lint": "phpstan analyse --memory-limit=2G --no-progress",
    "gen:catalog": "php -d memory_limit=2G scripts/gen-catalog.php"
  },
  "minimum-stability": "RC",
  "version": "1.0.0-rc.6"
}
