parameters:
    level: max
    paths:
        - src
        - tests
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Tests intentionally pass loosely-typed fixture arrays; production
        # src/ paths remain bound by the level: max iterable-type check.
        -
            identifier: missingType.iterableValue
            path: tests/*
        # PHPUnit's CoversClass attribute is marked IS_REPEATABLE at the
        # attribute-class level but older phpstan stubs read it as
        # non-repeatable; safe to suppress in test code.
        - '#Attribute class PHPUnit\\Framework\\Attributes\\CoversClass is not repeatable#'
        # Tests routinely round-trip through json_decode; assertions in the
        # test verify shape explicitly so static narrowing isn't useful.
        -
            message: '#Cannot access offset .* on mixed\.#'
            path: tests/*
        -
            message: '#Cannot cast mixed to (int|string)\.#'
            path: tests/*
        -
            message: '#expects array\|ArrayAccess<\(int\|string\), mixed>, mixed given\.#'
            path: tests/*
        # Anonymous capture properties in core transport tests are written
        # by the test scenario and asserted indirectly via the side effect
        # it produces; the "never read" warning here is a stylistic check
        # PHPStan can't satisfy without breaking the test.
        -
            message: '#is never read, only written\.#'
            path: tests/Core/*
        # The core Sleeper test fake intentionally exposes a `$calls` log
        # via a dynamic property on the interface alias; PHPStan can't see
        # that an anonymous class implementing Sleeper carries it.
        -
            message: '#Access to an undefined property Sah\\Sdk\\Core\\Sleeper::\$calls\.#'
            path: tests/Core/RetryClientTest.php
        # Account-namespace tests assert envelope `data` shape after a
        # mocked HTTP exchange; the envelope's `data` is intentionally
        # `mixed` and the test narrowing happens at runtime via the
        # client's typed value objects (BrandingDetail / CaseDetail /
        # EmailCaseAck). PHPStan cannot see through the require/json
        # round-trip.
        -
            message: '#Cannot access property \$(imoName|hideAffiliateLeads|caseId|to|status) on mixed\.#'
            path: tests/Account/*
        # The negative-test for EmailClient intentionally calls
        # `enqueue` with an incomplete array literal to assert the
        # InvalidArgumentException; PHPStan correctly notices the
        # missing required `body` key.
        -
            message: '#expects array\{to: string, subject: string, body: string.*\}#'
            path: tests/Account/AccountClientTest.php
        # IsaTest exercises the package-private CredentialState via
        # reflection so the listener path can be tested without hitting
        # the network. PHPStan loses the narrowing through
        # ReflectionProperty::getValue().
        -
            message: '#Cannot call method refreshLicenseKey\(\) on mixed\.#'
            path: tests/IsaTest.php
